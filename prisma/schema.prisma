generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AssetType {
  STOCK
  OPTION
  FUTURE
  FOREX
  CRYPTO
  ETF
  OTHER
}

enum Side {
  BUY
  SELL
}

enum JournalDirection {
  LONG
  SHORT
}

enum JournalStatus {
  DRAFT
  WATCHING
  MISSED
  PASSED
  INVALIDATED
  PLAYBOOK
  ARCHIVED
}

enum MacroSentiment {
  BULLISH
  NEUTRAL
  BEARISH
}

enum JournalTagCategory {
  SETUP
  LESSON
  MISTAKE
  CONTEXT
  CUSTOM
}

enum JournalMarkerType {
  IDEAL_ENTRY
  STOP
  TARGET
  IDEAL_EXIT
  MISSED_TRIGGER
  DECISION_POINT
}

enum JournalOutcomeStatus {
  UNREVIEWED
  TRIGGERED
  NEVER_TRIGGERED
  WORKED_WITHOUT_ME
  FAILED
  STILL_DEVELOPING
}

enum JournalMarketRegime {
  UNKNOWN
  RISK_ON
  MIXED
  RISK_OFF
}

enum JournalTrendState {
  UNKNOWN
  BULLISH
  NEUTRAL
  BEARISH
}

enum JournalChartPurpose {
  THESIS
  TRIGGER
  MARKET_CONTEXT
  PEER_CONTEXT
  FOLLOW_THROUGH
  REVIEW
  CUSTOM
}

enum JournalRuleCheckStatus {
  PASS
  FAIL
  NA
}

enum JournalReviewPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum JournalActionStatus {
  OPEN
  DONE
  ARCHIVED
}

model Account {
  id                String             @id @default(cuid())
  name              String
  ibkrAccount       String             @unique
  baseCurrency      String             @default("USD")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  executions        Execution[]
  positions         Position[]
  positionSnapshots PositionSnapshot[]
  snapshots         DailySnapshot[]
  dayNotes          DayNote[]
  symbolNotes       SymbolNote[]
  importBatches     ImportBatch[]
  closedTrades      ClosedTrade[]
}

model Instrument {
  id                String             @id @default(cuid())
  symbol            String
  exchange          String?
  assetType         AssetType          @default(STOCK)
  currency          String             @default("USD")
  executions        Execution[]
  positions         Position[]
  positionSnapshots PositionSnapshot[]
  symbolNotes       SymbolNote[]
  closedTrades      ClosedTrade[]

  @@unique([symbol, exchange, assetType])
}

model ImportBatch {
  id           String      @id @default(cuid())
  filename     String
  fileType     String
  importedAt   DateTime    @default(now())
  accountId    String?
  account      Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  rowsSeen     Int         @default(0)
  rowsImported Int         @default(0)
  rowsSkipped  Int         @default(0)
  notes        String?
  executions   Execution[]
}

model Execution {
  id                    String                 @id @default(cuid())
  dedupeKey             String                 @unique
  accountId             String
  account               Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId          String
  instrument            Instrument             @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  importBatchId         String?
  importBatch           ImportBatch?           @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  executedAt            DateTime
  side                  Side
  quantity              Float
  price                 Float
  commission            Float                  @default(0)
  fees                  Float                  @default(0)
  currency              String                 @default("USD")
  orderId               String?
  strategy              String?
  createdAt             DateTime               @default(now())
  tradeNote             TradeNote?
  tags                  ExecutionTag[]
  closedTradeExecutions ClosedTradeExecution[]
  analytics             ExecutionAnalytics?

  @@index([executedAt])
  @@index([accountId, executedAt])
  @@index([accountId, instrumentId, executedAt])
}

model Position {
  id            String     @id @default(cuid())
  accountId     String
  account       Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId  String
  instrument    Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  quantity      Float
  avgCost       Float
  unrealizedPnl Float?
  currency      String     @default("USD")
  updatedAt     DateTime   @updatedAt

  @@unique([accountId, instrumentId])
}

model PositionSnapshot {
  id            String     @id @default(cuid())
  accountId     String
  account       Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId  String
  instrument    Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  date          DateTime
  quantity      Float
  avgCost       Float
  unrealizedPnl Float?
  currency      String     @default("USD")
  createdAt     DateTime   @default(now())

  @@unique([accountId, instrumentId, date])
  @@index([accountId, date])
}

model DailySnapshot {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date          DateTime
  equity        Float?
  realizedPnl   Float?
  unrealizedPnl Float?
  currency      String   @default("USD")
  createdAt     DateTime @default(now())

  @@unique([accountId, date])
  @@index([date])
}

model Tag {
  id               String            @id @default(cuid())
  name             String            @unique
  createdAt        DateTime          @default(now())
  executionTags    ExecutionTag[]
  dayNoteTags      DayNoteTag[]
  symbolNoteTags   SymbolNoteTag[]
  journalEntryTags JournalEntryTag[]
}

model ExecutionTag {
  executionId String
  tagId       String
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([executionId, tagId])
}

model TradeNote {
  id          String    @id @default(cuid())
  executionId String    @unique
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DayNote {
  id        String       @id @default(cuid())
  accountId String
  account   Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date      DateTime
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tags      DayNoteTag[]

  @@unique([accountId, date])
}

model ClosedTradeNote {
  id        String   @id @default(cuid())
  groupKey  String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClosedTrade {
  groupKey         String                 @id
  accountId        String
  account          Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId     String
  instrument       Instrument             @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  symbol           String
  direction        String
  openTime         DateTime
  closeTime        DateTime
  tradeDate        DateTime
  totalQuantity    Float
  avgEntryPrice    Float
  avgExitPrice     Float
  grossRealizedPnl Float
  openingQuantity  Float
  closingQuantity  Float
  realizedPnl      Float
  totalCommission  Float
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  executions       ClosedTradeExecution[]

  @@index([tradeDate])
  @@index([accountId, tradeDate])
  @@index([symbol, tradeDate])
}

model ClosedTradeExecution {
  id                  String      @id @default(cuid())
  closedTradeGroupKey String
  closedTrade         ClosedTrade @relation(fields: [closedTradeGroupKey], references: [groupKey], onDelete: Cascade)
  executionId         String
  execution           Execution   @relation(fields: [executionId], references: [id], onDelete: Cascade)
  sortOrder           Int
  executedAt          DateTime
  side                Side
  quantity            Float
  price               Float
  commission          Float       @default(0)
  fees                Float       @default(0)

  @@index([closedTradeGroupKey, sortOrder])
  @@index([executionId])
  @@index([side, executedAt])
}

model ExecutionAnalytics {
  executionId      String    @id
  execution        Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  realizedPnl      Float
  grossRealizedPnl Float
  cumulativePnl    Float
  matchedQuantity  Float
  avgHoldTimeMs    Float
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SymbolNote {
  id           String          @id @default(cuid())
  accountId    String
  account      Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  instrumentId String
  instrument   Instrument      @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  thesis       String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  tags         SymbolNoteTag[]

  @@unique([accountId, instrumentId])
}

model DayNoteTag {
  dayNoteId String
  tagId     String
  dayNote   DayNote @relation(fields: [dayNoteId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([dayNoteId, tagId])
}

model SymbolNoteTag {
  symbolNoteId String
  tagId        String
  symbolNote   SymbolNote @relation(fields: [symbolNoteId], references: [id], onDelete: Cascade)
  tag          Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([symbolNoteId, tagId])
}

model JournalEntry {
  id                    String                   @id @default(cuid())
  symbol                String
  ideaDate              DateTime                 @default(now())
  direction             JournalDirection         @default(LONG)
  status                JournalStatus            @default(DRAFT)
  playbookId            String?
  playbook              JournalPlaybook?         @relation(fields: [playbookId], references: [id], onDelete: SetNull)
  setup                 String?
  timeframe             String                   @default("1D")
  macroSentiment        MacroSentiment           @default(NEUTRAL)
  thesis                String                   @default("")
  trigger               String                   @default("")
  riskPlan              String                   @default("")
  idealExecutionPlan    String                   @default("")
  missedReason          String                   @default("")
  marketContext         String                   @default("")
  peerContext           String                   @default("")
  rating                Int?
  lessonLearned         String                   @default("")
  plannedEntry          Float?
  plannedStop           Float?
  plannedTarget1        Float?
  plannedTarget2        Float?
  plannedTarget3        Float?
  invalidationLevel     Float?
  expectedR             Float?
  actualTriggerAt       DateTime?
  followThroughDays     Int?
  mfeR                  Float?
  maeR                  Float?
  bestExitR             Float?
  outcomeStatus         JournalOutcomeStatus     @default(UNREVIEWED)
  outcomeNotes          String                   @default("")
  confidenceScore       Int?
  planClarityScore      Int?
  preparationScore      Int?
  patienceScore         Int?
  ruleAdherenceScore    Int?
  emotionalState        String?
  wouldTakeAgain        Boolean?
  marketRegime          JournalMarketRegime      @default(UNKNOWN)
  spyTrend              JournalTrendState        @default(UNKNOWN)
  qqqTrend              JournalTrendState        @default(UNKNOWN)
  iwmTrend              JournalTrendState        @default(UNKNOWN)
  sectorTrend           JournalTrendState        @default(UNKNOWN)
  sectorEtf             String?
  breadthNotes          String                   @default("")
  catalystNotes         String                   @default("")
  relativeStrengthNotes String                   @default("")
  autoDraft             Boolean                  @default(false)
  reviewDueAt           DateTime?
  outcomeCalculatedAt   DateTime?
  outcomeCalculationJson String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  charts                JournalChart[]
  tags                  JournalEntryTag[]
  contextSnapshots      JournalContextSnapshot[]
  links                 JournalLink[]
  ruleChecks            JournalEntryRuleCheck[]
  playbookExamples      JournalPlaybookExample[]

  @@index([ideaDate])
  @@index([symbol, ideaDate])
  @@index([status, ideaDate])
  @@index([macroSentiment, ideaDate])
  @@index([playbookId, ideaDate])
  @@index([outcomeStatus, ideaDate])
  @@index([marketRegime, ideaDate])
  @@index([autoDraft, updatedAt])
  @@index([reviewDueAt])
}

model JournalChart {
  id                    String               @id @default(cuid())
  journalEntryId        String
  journalEntry          JournalEntry         @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  symbol                String
  timeframe             String               @default("1D")
  purpose               JournalChartPurpose  @default(CUSTOM)
  compareSymbol         String?
  rangeStart            DateTime?
  rangeEnd              DateTime?
  tradingViewLayoutJson String?
  screenshotKey         String?
  screenshotUrl         String?
  caption               String               @default("")
  width                 Int?
  height                Int?
  mimeType              String?
  markers               JournalChartMarker[]
  playbookExamples      JournalPlaybookExample[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([journalEntryId, createdAt])
  @@index([symbol, timeframe])
  @@index([purpose])
}

model JournalChartMarker {
  id           String            @id @default(cuid())
  chartId      String
  chart        JournalChart      @relation(fields: [chartId], references: [id], onDelete: Cascade)
  markerType   JournalMarkerType
  time         DateTime?
  price        Float?
  label        String?
  metadataJson String?
  createdAt    DateTime          @default(now())

  @@index([chartId])
  @@index([markerType])
}

model JournalEntryTag {
  journalEntryId String
  tagId          String
  category       JournalTagCategory @default(CUSTOM)
  journalEntry   JournalEntry       @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  tag            Tag                @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([journalEntryId, tagId, category])
  @@index([tagId, category])
}

model JournalContextSnapshot {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  provider       String
  kind           String
  payloadJson    String       @default("{}")
  createdAt      DateTime     @default(now())

  @@index([journalEntryId, kind, createdAt])
}

model JournalLink {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  linkType       String
  targetType     String
  targetId       String?
  url            String?
  label          String?
  createdAt      DateTime     @default(now())

  @@index([journalEntryId, linkType])
  @@index([targetType, targetId])
}

model JournalPlaybook {
  id                String                @id @default(cuid())
  name              String                @unique
  setupType         String?
  description       String                @default("")
  idealConditions   String                @default("")
  invalidationRules String                @default("")
  marketRegimeFit   String                @default("")
  archived          Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  entries           JournalEntry[]
  rules             JournalPlaybookRule[]
  examples          JournalPlaybookExample[]

  @@index([archived, name])
}

model JournalPlaybookRule {
  id         String                  @id @default(cuid())
  playbookId String
  playbook   JournalPlaybook         @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  text       String
  category   String                  @default("SETUP")
  required   Boolean                 @default(true)
  sortOrder  Int                     @default(0)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  checks     JournalEntryRuleCheck[]

  @@index([playbookId, sortOrder])
}

model JournalEntryRuleCheck {
  id             String                 @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry           @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  playbookRuleId String?
  playbookRule   JournalPlaybookRule?   @relation(fields: [playbookRuleId], references: [id], onDelete: SetNull)
  status         JournalRuleCheckStatus @default(NA)
  notes          String                 @default("")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([journalEntryId, playbookRuleId])
  @@index([journalEntryId])
  @@index([playbookRuleId, status])
}

model JournalReview {
  id               String                @id @default(cuid())
  period           JournalReviewPeriod
  startDate        DateTime
  endDate          DateTime
  summary          String                @default("")
  bestIdea         String                @default("")
  bestIdeaEntryId  String?
  worstMiss        String                @default("")
  worstMissEntryId String?
  recurringLesson  String                @default("")
  nextFocus        String                @default("")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  actions          JournalReviewAction[]

  @@index([period, startDate])
}

model JournalReviewAction {
  id             String              @id @default(cuid())
  reviewId       String
  review         JournalReview       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  label          String
  status         JournalActionStatus @default(OPEN)
  journalEntryId String?
  playbookId     String?
  dueDate        DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([reviewId, status])
  @@index([journalEntryId])
  @@index([playbookId])
}

model JournalSavedView {
  id            String   @id @default(cuid())
  name          String
  viewType      String
  filtersJson   String   @default("{}")
  sortKey       String?
  sortDirection String   @default("desc")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([viewType, name])
  @@index([viewType, updatedAt])
}

model JournalPlaybookExample {
  id             String          @id @default(cuid())
  playbookId     String
  playbook       JournalPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  journalEntryId String
  journalEntry   JournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  chartId        String?
  chart          JournalChart?   @relation(fields: [chartId], references: [id], onDelete: SetNull)
  note           String          @default("")
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())

  @@unique([playbookId, journalEntryId, chartId])
  @@index([playbookId, sortOrder])
  @@index([journalEntryId])
  @@index([chartId])
}
